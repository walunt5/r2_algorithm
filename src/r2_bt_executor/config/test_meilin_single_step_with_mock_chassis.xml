<root BTCPP_format="4" main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <Sequence name="test_meilin_single_step_with_mock_chassis">

      <!-- 1. 从路线中取第 0 个目标方块：B2 -->
      <R2GetNextManualBlockNode
        manual_block_sequence="B2,B3,EXIT_ZONE"
        route_index="0"
        to_block="{to_block}" />

      <!-- 2. 根据 ENTRY -> B2 查 transition 信息 -->
      <R2GetTransitionInfoNode
        from_block="ENTRY"
        to_block="{to_block}"
        edge_id="{edge_id}"
        approach_goal_name="{approach_goal_name}"
        landing_goal_name="{landing_goal_name}" />

      <!-- 3. mock 检查 Odin 定位是否正常 -->
      <R2CheckOdinLocalizationOkMockNode
        source_frame="map"
        target_frame="odin"
        timeout_ms="1000" />

      <!-- 4. mock 对准 approach_goal_name -->
      <R2OdinPosePidAlignMockNode
        edge_id="{edge_id}"
        goal_name="{approach_goal_name}"
        timeout_ms="3000" />

      <!-- 5. 查目标方块高度 -->
      <R2GetBlockHeightNode
        block="{to_block}"
        height="{next_h}" />

      <!-- 6. 算高度差：ENTRY 高度 0，B2 高度 200 -->
      <R2CalculateHeightDeltaNode
        current_h="0"
        next_h="{next_h}"
        delta_h="{delta_h}" />

      <!-- 7. 根据高度差生成底盘动作类型 -->
      <R2BuildMeilinChassisCmdTypeNode
        delta_h="{delta_h}"
        cmd_type="{chassis_cmd_type}" />

      <!-- 8. 发送底盘 StepCommand 给 mock chassis -->
      <R2ChassisStepCommandNode
        action_name="/r2_chassis/step_command"
        cmd_type="{chassis_cmd_type}"
        from_block="ENTRY"
        target_block="{to_block}"
        current_h="0"
        target_h="{next_h}"
        edge_id="{edge_id}"
        timeout_sec="10.0"
        server_timeout_ms="3000"
        result_timeout_ms="15000" />

      <R2ForceSuccess />

    </Sequence>
  </BehaviorTree>
</root>