<root BTCPP_format="4" main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <Sequence name="test_meilin_route_pick">

      <R2CheckListNotEmptyNode
        text="B2,B3,EXIT_ZONE" />

      <R2PeekFirstManualBlockNode
        manual_block_sequence="B2,B3,EXIT_ZONE"
        first_block="{first_block}" />

      <R2BlackboardCheckStringNode
        value="{first_block}"
        expected="B2" />

      <R2GetNextManualBlockNode
        manual_block_sequence="B2,B3,EXIT_ZONE"
        route_index="0"
        to_block="{to_block_0}" />

      <R2BlackboardCheckStringNode
        value="{to_block_0}"
        expected="B2" />

      <R2GetNextManualBlockNode
        manual_block_sequence="B2,B3,EXIT_ZONE"
        route_index="1"
        to_block="{to_block_1}" />

      <R2BlackboardCheckStringNode
        value="{to_block_1}"
        expected="B3" />

      <R2GetNextManualBlockNode
        manual_block_sequence="B2,B3,EXIT_ZONE"
        route_index="2"
        to_block="{to_block_2}" />

      <R2BlackboardCheckStringNode
        value="{to_block_2}"
        expected="EXIT_ZONE" />

      <R2ForceSuccess />
    </Sequence>
  </BehaviorTree>
</root>