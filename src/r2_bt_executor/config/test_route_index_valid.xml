<root BTCPP_format="4" main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <Sequence name="test_route_index_valid">

      <!-- 合法：route_index=0，对应 B2 -->
      <R2CheckRouteIndexValidNode
        manual_block_sequence="B2,B3,EXIT_ZONE"
        route_index="0"
        route_len="{route_len_0}" />

      <!-- 合法：route_index=1，对应 B3 -->
      <R2CheckRouteIndexValidNode
        manual_block_sequence="B2,B3,EXIT_ZONE"
        route_index="1"
        route_len="{route_len_1}" />

      <!-- 合法：route_index=2，对应 EXIT_ZONE -->
      <R2CheckRouteIndexValidNode
        manual_block_sequence="B2,B3,EXIT_ZONE"
        route_index="2"
        route_len="{route_len_2}" />

      <!-- 不合法：route_index=3，路线已经走完。
           这里用 Inverter 把 FAILURE 变成 SUCCESS，
           这样可以证明 route_index=3 确实被判成了不合法。 -->
      <Inverter>
        <R2CheckRouteIndexValidNode
          manual_block_sequence="B2,B3,EXIT_ZONE"
          route_index="3"
          route_len="{route_len_3}" />
      </Inverter>

      <!-- 不合法：route_index=-1 -->
      <Inverter>
        <R2CheckRouteIndexValidNode
          manual_block_sequence="B2,B3,EXIT_ZONE"
          route_index="-1"
          route_len="{route_len_negative}" />
      </Inverter>

      <R2ForceSuccess />

    </Sequence>
  </BehaviorTree>
</root>