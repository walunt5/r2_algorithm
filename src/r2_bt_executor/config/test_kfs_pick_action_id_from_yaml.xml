<root BTCPP_format="4" main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <Sequence name="test_kfs_pick_action_id_from_yaml">

      <R2BuildKfsPickActionIdFromYamlNode
        map_package="r2_bt_executor"
        map_file="meilin_map.yaml"
        delta_h="0"
        action_id="{action_id_0}" />

      <R2BuildKfsPickActionIdFromYamlNode
        map_package="r2_bt_executor"
        map_file="meilin_map.yaml"
        delta_h="200"
        action_id="{action_id_plus_200}" />

      <R2BuildKfsPickActionIdFromYamlNode
        map_package="r2_bt_executor"
        map_file="meilin_map.yaml"
        delta_h="-200"
        action_id="{action_id_minus_200}" />

      <R2BuildKfsPickActionIdFromYamlNode
        map_package="r2_bt_executor"
        map_file="meilin_map.yaml"
        delta_h="400"
        action_id="{action_id_plus_400}" />

      <R2BuildKfsPickActionIdFromYamlNode
        map_package="r2_bt_executor"
        map_file="meilin_map.yaml"
        delta_h="-400"
        action_id="{action_id_minus_400}" />

      <R2ForceSuccess />

    </Sequence>
  </BehaviorTree>
</root>