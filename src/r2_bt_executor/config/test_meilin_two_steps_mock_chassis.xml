<root BTCPP_format="4" main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <Sequence name="test_meilin_two_steps_mock_chassis">

      <!-- 初始化状态：机器人从 ENTRY 出发 -->
      <R2SetBlackboardStringNode
        value="ENTRY"
        output="{current_block}" />

      <R2SetBlackboardIntNode
        value="0"
        output="{current_h}" />

      <R2SetBlackboardIntNode
        value="0"
        output="{route_index}" />

      <!-- ========================= -->
      <!-- 第 1 段：ENTRY -> B2 -->
      <!-- ========================= -->

      <R2GetNextManualBlockNode
        manual_block_sequence="B2,B3,EXIT_ZONE"
        route_index="{route_index}"
        to_block="{to_block}" />

      <R2GetTransitionInfoNode
        from_block="{current_block}"
        to_block="{to_block}"
        edge_id="{edge_id}"
        approach_goal_name="{approach_goal_name}"
        landing_goal_name="{landing_goal_name}" />

      <R2CheckOdinLocalizationOkMockNode
        source_frame="map"
        target_frame="odin"
        timeout_ms="1000" />

      <R2OdinPosePidAlignMockNode
        edge_id="{edge_id}"
        goal_name="{approach_goal_name}"
        timeout_ms="3000" />

      <R2GetBlockHeightNode
        block="{to_block}"
        height="{next_h}" />

      <R2CalculateHeightDeltaNode
        current_h="{current_h}"
        next_h="{next_h}"
        delta_h="{delta_h}" />

      <R2BuildMeilinChassisCmdTypeNode
        delta_h="{delta_h}"
        cmd_type="{chassis_cmd_type}" />

      <R2BlackboardCheckStringNode
        value="{chassis_cmd_type}"
        expected="CLIMB_200" />

      <R2ChassisStepCommandNode
        action_name="/r2_chassis/step_command"
        cmd_type="{chassis_cmd_type}"
        from_block="{current_block}"
        target_block="{to_block}"
        current_h="{current_h}"
        target_h="{next_h}"
        edge_id="{edge_id}"
        timeout_sec="10.0"
        server_timeout_ms="3000"
        result_timeout_ms="15000" />

      <!-- 第 1 段结束后更新状态：现在已经在 B2 -->
      <R2SetBlackboardStringNode
        value="{to_block}"
        output="{current_block}" />

      <R2SetBlackboardIntNode
        value="{next_h}"
        output="{current_h}" />

      <R2IncrementIntNode
        input="{route_index}"
        step="1"
        output="{route_index}" />

      <R2BlackboardCheckStringNode
        value="{current_block}"
        expected="B2" />

      <!-- ========================= -->
      <!-- 第 2 段：B2 -> B3 -->
      <!-- ========================= -->

      <R2GetNextManualBlockNode
        manual_block_sequence="B2,B3,EXIT_ZONE"
        route_index="{route_index}"
        to_block="{to_block}" />

      <R2GetTransitionInfoNode
        from_block="{current_block}"
        to_block="{to_block}"
        edge_id="{edge_id}"
        approach_goal_name="{approach_goal_name}"
        landing_goal_name="{landing_goal_name}" />

      <R2CheckOdinLocalizationOkMockNode
        source_frame="map"
        target_frame="odin"
        timeout_ms="1000" />

      <R2OdinPosePidAlignMockNode
        edge_id="{edge_id}"
        goal_name="{approach_goal_name}"
        timeout_ms="3000" />

      <R2GetBlockHeightNode
        block="{to_block}"
        height="{next_h}" />

      <R2CalculateHeightDeltaNode
        current_h="{current_h}"
        next_h="{next_h}"
        delta_h="{delta_h}" />

      <R2BuildMeilinChassisCmdTypeNode
        delta_h="{delta_h}"
        cmd_type="{chassis_cmd_type}" />

      <!-- B2 高度 200，B3 高度 200，所以应该是 MOVE_FLAT -->
      <R2BlackboardCheckStringNode
        value="{chassis_cmd_type}"
        expected="MOVE_FLAT" />

      <R2ChassisStepCommandNode
        action_name="/r2_chassis/step_command"
        cmd_type="{chassis_cmd_type}"
        from_block="{current_block}"
        target_block="{to_block}"
        current_h="{current_h}"
        target_h="{next_h}"
        edge_id="{edge_id}"
        timeout_sec="10.0"
        server_timeout_ms="3000"
        result_timeout_ms="15000" />

      <!-- 第 2 段结束后更新状态：现在已经在 B3 -->
      <R2SetBlackboardStringNode
        value="{to_block}"
        output="{current_block}" />

      <R2SetBlackboardIntNode
        value="{next_h}"
        output="{current_h}" />

      <R2IncrementIntNode
        input="{route_index}"
        step="1"
        output="{route_index}" />

      <R2BlackboardCheckStringNode
        value="{current_block}"
        expected="B3" />

      <R2ForceSuccess />

    </Sequence>
  </BehaviorTree>
</root>