<root BTCPP_format="4" main_tree_to_execute="MainTree">

  <BehaviorTree ID="MainTree">
    <Sequence name="test_meilin_route_guard_subtree">

      <!-- ===================================================== -->
      <!-- 测试 1：route_index=0，路线未结束，应该执行一段 -->
      <!-- ===================================================== -->

      <R2SetBlackboardStringNode
        value="ENTRY"
        output="{current_block}" />

      <R2SetBlackboardIntNode
        value="0"
        output="{current_h}" />

      <R2SetBlackboardIntNode
        value="0"
        output="{route_index}" />

      <SubTree
        ID="MeilinGuardedOneStep"
        manual_block_sequence="B2,B3,EXIT_ZONE"
        expected_cmd_type="CLIMB_200"
        expected_current_block_after_step="B2"
        current_block="{current_block}"
        current_h="{current_h}"
        route_index="{route_index}" />

      <!-- 执行完第 1 段后，应该已经在 B2 -->
      <R2BlackboardCheckStringNode
        value="{current_block}"
        expected="B2" />

      <!-- ===================================================== -->
      <!-- 测试 2：route_index=3，路线已结束，不应该再执行底盘 -->
      <!-- ===================================================== -->

      <R2SetBlackboardStringNode
        value="EXIT_ZONE"
        output="{current_block}" />

      <R2SetBlackboardIntNode
        value="0"
        output="{current_h}" />

      <R2SetBlackboardIntNode
        value="3"
        output="{route_index}" />

      <SubTree
        ID="MeilinGuardedOneStep"
        manual_block_sequence="B2,B3,EXIT_ZONE"
        expected_cmd_type="ROUTE_DONE_NO_CHASSIS"
        expected_current_block_after_step="EXIT_ZONE"
        current_block="{current_block}"
        current_h="{current_h}"
        route_index="{route_index}" />

      <!-- route_index=3 时，不应该改变 current_block -->
      <R2BlackboardCheckStringNode
        value="{current_block}"
        expected="EXIT_ZONE" />

      <R2ForceSuccess />

    </Sequence>
  </BehaviorTree>


  <!-- ===================================================== -->
  <!-- 带路线结束保护的一步执行子树 -->
  <!-- ===================================================== -->
  <BehaviorTree ID="MeilinGuardedOneStep">
    <Fallback name="meilin_guarded_one_step">

      <!-- 如果 route_index 有效，就执行一段 -->
      <Sequence name="do_one_step_if_route_index_valid">

        <R2CheckRouteIndexValidNode
          manual_block_sequence="{manual_block_sequence}"
          route_index="{route_index}"
          route_len="{route_len}" />

        <SubTree
          ID="MeilinOneStep"
          manual_block_sequence="{manual_block_sequence}"
          expected_cmd_type="{expected_cmd_type}"
          expected_current_block_after_step="{expected_current_block_after_step}"
          current_block="{current_block}"
          current_h="{current_h}"
          route_index="{route_index}" />

      </Sequence>

      <!-- 如果 route_index 无效，说明路线已经结束，直接 SUCCESS -->
      <R2ForceSuccess />

    </Fallback>
  </BehaviorTree>


  <!-- ===================================================== -->
  <!-- 原来的一段路线执行子树 -->
  <!-- ===================================================== -->
  <BehaviorTree ID="MeilinOneStep">
    <Sequence name="meilin_one_step">

      <!-- 1. 根据 route_index 从路线中取目标方块 -->
      <R2GetNextManualBlockNode
        manual_block_sequence="{manual_block_sequence}"
        route_index="{route_index}"
        to_block="{to_block}" />

      <!-- 2. 根据 current_block -> to_block 查 transition -->
      <R2GetTransitionInfoNode
        from_block="{current_block}"
        to_block="{to_block}"
        edge_id="{edge_id}"
        approach_goal_name="{approach_goal_name}"
        landing_goal_name="{landing_goal_name}" />

      <!-- 3. Odin 定位检查，当前是 mock -->
      <R2CheckOdinLocalizationOkMockNode
        source_frame="map"
        target_frame="odin"
        timeout_ms="1000" />

      <!-- 4. 对准本段 approach 点，当前是 mock -->
      <R2OdinPosePidAlignMockNode
        edge_id="{edge_id}"
        goal_name="{approach_goal_name}"
        timeout_ms="3000" />

      <!-- 5. 查目标方块高度 -->
      <R2GetBlockHeightNode
        block="{to_block}"
        height="{next_h}" />

      <!-- 6. 计算高度差 -->
      <R2CalculateHeightDeltaNode
        current_h="{current_h}"
        next_h="{next_h}"
        delta_h="{delta_h}" />

      <!-- 7. 根据高度差生成底盘命令 -->
      <R2BuildMeilinChassisCmdTypeNode
        delta_h="{delta_h}"
        cmd_type="{chassis_cmd_type}" />

      <!-- 8. 检查生成的底盘命令是否符合预期 -->
      <R2BlackboardCheckStringNode
        value="{chassis_cmd_type}"
        expected="{expected_cmd_type}" />

      <!-- 9. 发送底盘动作 -->
      <R2ChassisStepCommandNode
        action_name="/r2_chassis/step_command"
        cmd_type="{chassis_cmd_type}"
        from_block="{current_block}"
        target_block="{to_block}"
        current_h="{current_h}"
        target_h="{next_h}"
        edge_id="{edge_id}"
        timeout_sec="10.0"
        server_timeout_ms="3000"
        result_timeout_ms="15000" />

      <!-- 10. 一段结束后更新状态 -->
      <R2SetBlackboardStringNode
        value="{to_block}"
        output="{current_block}" />

      <R2SetBlackboardIntNode
        value="{next_h}"
        output="{current_h}" />

      <R2IncrementIntNode
        input="{route_index}"
        step="1"
        output="{route_index}" />

      <!-- 11. 检查 current_block 是否符合预期 -->
      <R2BlackboardCheckStringNode
        value="{current_block}"
        expected="{expected_current_block_after_step}" />

    </Sequence>
  </BehaviorTree>

</root>