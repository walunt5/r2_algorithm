<root BTCPP_format="4" main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <Sequence name="test_chassis_cmd_type_from_yaml">

      <R2BuildChassisCmdTypeFromYamlNode
        map_package="r2_bt_executor"
        map_file="meilin_map.yaml"
        delta_h="0"
        cmd_type="{cmd_0}" />

      <R2BuildChassisCmdTypeFromYamlNode
        map_package="r2_bt_executor"
        map_file="meilin_map.yaml"
        delta_h="200"
        cmd_type="{cmd_plus_200}" />

      <R2BuildChassisCmdTypeFromYamlNode
        map_package="r2_bt_executor"
        map_file="meilin_map.yaml"
        delta_h="400"
        cmd_type="{cmd_plus_400}" />

      <R2BuildChassisCmdTypeFromYamlNode
        map_package="r2_bt_executor"
        map_file="meilin_map.yaml"
        delta_h="-200"
        cmd_type="{cmd_minus_200}" />

      <R2BuildChassisCmdTypeFromYamlNode
        map_package="r2_bt_executor"
        map_file="meilin_map.yaml"
        delta_h="-400"
        cmd_type="{cmd_minus_400}" />

      <R2ForceSuccess />

    </Sequence>
  </BehaviorTree>
</root>