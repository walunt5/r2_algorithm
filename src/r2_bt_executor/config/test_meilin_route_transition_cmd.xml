<root BTCPP_format="4" main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <Sequence name="test_meilin_route_transition_cmd">

      <R2GetNextManualBlockNode
        manual_block_sequence="B2,B3,EXIT_ZONE"
        route_index="0"
        to_block="{to_block}" />

      <R2GetTransitionInfoNode
        from_block="ENTRY"
        to_block="{to_block}"
        edge_id="{edge_id}"
        approach_goal_name="{approach_goal_name}"
        landing_goal_name="{landing_goal_name}" />

      <R2BlackboardCheckStringNode
        value="{edge_id}"
        expected="ENTRY_TO_B2" />

      <R2BlackboardCheckStringNode
        value="{approach_goal_name}"
        expected="ENTRY_TO_B2_APPROACH" />

      <R2BlackboardCheckStringNode
        value="{landing_goal_name}"
        expected="B2_LANDING" />

      <R2GetBlockHeightNode
        block="{to_block}"
        height="{next_h}" />

      <R2CalculateHeightDeltaNode
        current_h="0"
        next_h="{next_h}"
        delta_h="{delta_h}" />

      <R2BuildMeilinChassisCmdTypeNode
        delta_h="{delta_h}"
        cmd_type="{chassis_cmd_type}" />

      <R2BlackboardCheckStringNode
        value="{chassis_cmd_type}"
        expected="CLIMB_200" />

      <R2ForceSuccess />

    </Sequence>
  </BehaviorTree>
</root>