<root BTCPP_format="4" main_tree_to_execute="MainTree">

  <BehaviorTree ID="MainTree">
    <Sequence name="test_meilin_one_step_with_kfs_yaml">

      <!-- 初始化：假设机器人已经在 B2，高度 200，下一步目标是 B3 -->
      <R2SetBlackboardStringNode
        value="B2"
        output="{current_block}" />

      <R2SetBlackboardIntNode
        value="200"
        output="{current_h}" />

      <R2SetBlackboardIntNode
        value="0"
        output="{route_index}" />

      <!-- 执行一段：B2 -> B3，并在底盘动作前处理 B3 的 KFS -->
      <SubTree
        ID="MeilinOneStepWithKfsYaml"
        manual_block_sequence="B3"
        current_block="{current_block}"
        current_h="{current_h}"
        route_index="{route_index}" />

      <!-- 执行完后，应该已经移动到 B3 -->
      <R2BlackboardCheckStringNode
        value="{current_block}"
        expected="B3" />

      <R2ForceSuccess />

    </Sequence>
  </BehaviorTree>


  <!-- ===================================================== -->
  <!-- 单步：带 KFS YAML 判断的梅林一步执行 -->
  <!-- ===================================================== -->
  <BehaviorTree ID="MeilinOneStepWithKfsYaml">
    <Sequence name="meilin_one_step_with_kfs_yaml">

      <!-- 1. 根据 route_index 从路线中取目标方块。这里 manual_block_sequence 只有 B3 -->
      <R2GetNextManualBlockNode
        manual_block_sequence="{manual_block_sequence}"
        route_index="{route_index}"
        to_block="{to_block}" />

      <!-- 2. 根据 current_block -> to_block 查 transition -->
      <R2GetTransitionInfoNode
        from_block="{current_block}"
        to_block="{to_block}"
        edge_id="{edge_id}"
        approach_goal_name="{approach_goal_name}"
        landing_goal_name="{landing_goal_name}" />

      <!-- 3. Odin 定位检查，当前是 mock -->
      <R2CheckOdinLocalizationOkMockNode
        source_frame="map"
        target_frame="odin"
        timeout_ms="1000" />

      <!-- 4. Odin 对准 approach 点，当前是 mock -->
      <R2OdinPosePidAlignMockNode
        edge_id="{edge_id}"
        goal_name="{approach_goal_name}"
        timeout_ms="3000" />

      <!-- 5. 从 YAML 查目标方块高度，用于后面底盘动作 -->
      <R2GetBlockHeightFromYamlNode
        map_package="r2_bt_executor"
        map_file="meilin_map.yaml"
        block="{to_block}"
        height="{next_h}" />


      <!-- ===================================================== -->
      <!-- 6. KFS 分支：如果目标方块有 KFS，就先执行机械臂吸取 -->
      <!-- ===================================================== -->
      <Fallback name="handle_kfs_if_exists">

        <!-- 分支 A：目标方块有 KFS，执行吸取动作 -->
        <Sequence name="pick_kfs_if_exists">

          <!-- 6.1 从 YAML 判断目标方块是否有 KFS -->
          <R2CheckBlockHasKfsFromYamlNode
            map_package="r2_bt_executor"
            map_file="meilin_map.yaml"
            block="{to_block}"
            has_kfs="{has_kfs}" />

          <!-- 6.2 必须是 true 才继续 -->
          <R2BlackboardCheckBoolNode
            value="{has_kfs}"
            expected="true" />

          <!-- 6.3 从 YAML 读取 KFS 高度 -->
          <R2GetBlockKfsHeightFromYamlNode
            map_package="r2_bt_executor"
            map_file="meilin_map.yaml"
            block="{to_block}"
            kfs_height="{kfs_h}" />

          <!-- 6.4 计算 KFS 和当前机器人高度差 -->
          <R2CalculateHeightDeltaNode
            current_h="{current_h}"
            next_h="{kfs_h}"
            delta_h="{kfs_delta_h}" />

          <!-- 6.5 根据高度差生成机械臂 pick action_id -->
          <R2BuildKfsPickActionIdByDeltaNode
            delta_h="{kfs_delta_h}"
            action_id="{kfs_pick_action_id}" />

          <!-- 6.6 执行机械臂动作：target_id=2 表示 KFS 吸取机械臂 -->
          <R2ExecuteArmActionNode
            action_name="/r2_arm/execute_action"
            target_id="2"
            action_id="{kfs_pick_action_id}"
            timeout_ms="8000"
            param="0"
            flags="0"
            server_timeout_ms="3000"
            result_timeout_ms="10000" />

        </Sequence>

        <!-- 分支 B：没有 KFS，直接跳过。
             注意：这里是 fallback 的第二个分支。
             如果分支 A 因 has_kfs=false 失败，就会走到这里。 -->
        <R2ForceSuccess />

      </Fallback>


      <!-- ===================================================== -->
      <!-- 7. KFS 处理完后，再执行底盘动作 -->
      <!-- ===================================================== -->

      <!-- 7.1 计算底盘高度差 -->
      <R2CalculateHeightDeltaNode
        current_h="{current_h}"
        next_h="{next_h}"
        delta_h="{delta_h}" />

      <!-- 7.2 根据高度差生成底盘命令 -->
      <R2BuildMeilinChassisCmdTypeNode
        delta_h="{delta_h}"
        cmd_type="{chassis_cmd_type}" />

      <!-- 7.3 发送底盘动作 -->
      <R2ChassisStepCommandNode
        action_name="/r2_chassis/step_command"
        cmd_type="{chassis_cmd_type}"
        from_block="{current_block}"
        target_block="{to_block}"
        current_h="{current_h}"
        target_h="{next_h}"
        edge_id="{edge_id}"
        timeout_sec="10.0"
        server_timeout_ms="3000"
        result_timeout_ms="15000" />

      <!-- 8. 底盘一段结束后更新状态 -->
      <R2SetBlackboardStringNode
        value="{to_block}"
        output="{current_block}" />

      <R2SetBlackboardIntNode
        value="{next_h}"
        output="{current_h}" />

      <R2IncrementIntNode
        input="{route_index}"
        step="1"
        output="{route_index}" />

    </Sequence>
  </BehaviorTree>

</root>