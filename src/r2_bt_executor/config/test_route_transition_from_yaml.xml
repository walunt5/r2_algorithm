<root BTCPP_format="4" main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <Sequence name="test_route_transition_from_yaml">

      <R2GetRouteFromYamlNode
        map_package="r2_bt_executor"
        map_file="meilin_map.yaml"
        route_name="zone2_main"
        start_block="{start_block}"
        start_height="{start_height}"
        manual_block_sequence="{manual_block_sequence}" />

      <R2BlackboardCheckStringNode
        value="{start_block}"
        expected="ENTRY" />

      <R2SetBlackboardIntNode
        value="0"
        output="{route_index}" />

      <R2GetNextManualBlockNode
        manual_block_sequence="{manual_block_sequence}"
        route_index="{route_index}"
        to_block="{to_block}" />

      <R2BlackboardCheckStringNode
        value="{to_block}"
        expected="B2" />

      <R2GetTransitionInfoFromYamlNode
        map_package="r2_bt_executor"
        map_file="meilin_map.yaml"
        from_block="{start_block}"
        to_block="{to_block}"
        edge_id="{edge_id}"
        approach_goal_name="{approach_goal_name}"
        landing_goal_name="{landing_goal_name}" />

      <R2BlackboardCheckStringNode
        value="{edge_id}"
        expected="ENTRY_TO_B2" />

      <R2BlackboardCheckStringNode
        value="{approach_goal_name}"
        expected="ENTRY_TO_B2_APPROACH" />

      <R2BlackboardCheckStringNode
        value="{landing_goal_name}"
        expected="B2_LANDING" />

      <R2ForceSuccess />

    </Sequence>
  </BehaviorTree>
</root>