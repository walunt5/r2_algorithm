<root BTCPP_format="4" main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <Sequence name="test_route_finished">

      <!-- route_index=0，还没走完，所以 R2CheckRouteFinishedNode 应该 FAILURE。
           外面加 Inverter，把 FAILURE 翻成 SUCCESS。 -->
      <Inverter>
        <R2CheckRouteFinishedNode
          manual_block_sequence="B2,B3,EXIT_ZONE"
          route_index="0"
          route_len="{route_len_0}" />
      </Inverter>

      <!-- route_index=1，还没走完，也应该 FAILURE。 -->
      <Inverter>
        <R2CheckRouteFinishedNode
          manual_block_sequence="B2,B3,EXIT_ZONE"
          route_index="1"
          route_len="{route_len_1}" />
      </Inverter>

      <!-- route_index=2，还没走完，也应该 FAILURE。 -->
      <Inverter>
        <R2CheckRouteFinishedNode
          manual_block_sequence="B2,B3,EXIT_ZONE"
          route_index="2"
          route_len="{route_len_2}" />
      </Inverter>

      <!-- route_index=3，刚好等于路线长度，说明已经走完，应该 SUCCESS。 -->
      <R2CheckRouteFinishedNode
        manual_block_sequence="B2,B3,EXIT_ZONE"
        route_index="3"
        route_len="{route_len_3}" />

      <!-- route_index=4，超过路线长度，也应该认为已经走完，应该 SUCCESS。 -->
      <R2CheckRouteFinishedNode
        manual_block_sequence="B2,B3,EXIT_ZONE"
        route_index="4"
        route_len="{route_len_4}" />

      <!-- route_index=-1 是非法索引，不认为路线完成，应该 FAILURE。
           外面加 Inverter，把 FAILURE 翻成 SUCCESS。 -->
      <Inverter>
        <R2CheckRouteFinishedNode
          manual_block_sequence="B2,B3,EXIT_ZONE"
          route_index="-1"
          route_len="{route_len_negative}" />
      </Inverter>

      <R2ForceSuccess />

    </Sequence>
  </BehaviorTree>
</root>