<root BTCPP_format="4" main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <Sequence name="test_meilin_logic">

      <R2CalculateHeightDeltaNode
        current_h="0"
        next_h="200"
        delta_h="{delta_h}" />

      <R2BuildMeilinChassisCmdTypeNode
        delta_h="{delta_h}"
        cmd_type="{chassis_cmd_type}" />

      <R2BuildKfsPickActionIdByDeltaNode
        delta_h="200"
        action_id="{kfs_pick_action_id}" />

      <R2ForceSuccess />

    </Sequence>
  </BehaviorTree>
</root>