<root BTCPP_format="4" main_tree_to_execute="MainTree">

  <BehaviorTree ID="MainTree">
    <Sequence name="meilin_zone2_task">

      <R2GetRouteFromYamlNode
        map_package="r2_bt_executor"
        map_file="meilin_map.yaml"
        route_name="zone2_main"
        start_block="{start_block}"
        start_height="{start_height}"
        manual_block_sequence="{manual_block_sequence}" />

      <R2SetBlackboardStringNode
        value="{start_block}"
        output="{current_block}" />

      <R2SetBlackboardIntNode
        value="{start_height}"
        output="{current_h}" />

      <R2SetBlackboardIntNode
        value="0"
        output="{route_index}" />

      <Fallback name="repeat_route_until_done_or_success">

        <KeepRunningUntilFailure name="repeat_until_route_finished">

          <Sequence name="one_loop_body">

            <Inverter>
              <R2CheckRouteFinishedNode
                manual_block_sequence="{manual_block_sequence}"
                route_index="{route_index}"
                route_len="{route_len}" />
            </Inverter>

            <SubTree
              ID="MeilinOneStepWithKfsTransferYaml"
              manual_block_sequence="{manual_block_sequence}"
              current_block="{current_block}"
              current_h="{current_h}"
              route_index="{route_index}" />

          </Sequence>

        </KeepRunningUntilFailure>

        <R2ForceSuccess />

      </Fallback>

      <R2BlackboardCheckStringNode
        value="{current_block}"
        expected="EXIT_ZONE" />

      <R2CheckRouteFinishedNode
        manual_block_sequence="{manual_block_sequence}"
        route_index="{route_index}"
        route_len="{final_route_len}" />

      <R2ForceSuccess />

    </Sequence>
  </BehaviorTree>


  <BehaviorTree ID="MeilinOneStepWithKfsTransferYaml">
    <Sequence name="meilin_one_step_with_kfs_transfer_yaml">

      <R2GetNextManualBlockNode
        manual_block_sequence="{manual_block_sequence}"
        route_index="{route_index}"
        to_block="{to_block}" />

      <R2GetTransitionInfoFromYamlNode
        map_package="r2_bt_executor"
        map_file="meilin_map.yaml"
        from_block="{current_block}"
        to_block="{to_block}"
        edge_id="{edge_id}"
        approach_goal_name="{approach_goal_name}"
        landing_goal_name="{landing_goal_name}" />

      <R2CheckOdinLocalizationOkMockNode
        source_frame="map"
        target_frame="odin"
        timeout_ms="1000" />

      <R2OdinPosePidAlignActionNode
        action_name="/r2_odin_pose_pid/align"
        goal_name="{approach_goal_name}"
        use_goal_name="true"
        timeout_sec="5.0"
        server_timeout_ms="3000"
        result_timeout_ms="8000" />

      <R2GetBlockHeightFromYamlNode
        map_package="r2_bt_executor"
        map_file="meilin_map.yaml"
        block="{to_block}"
        height="{next_h}" />

      <R2CheckBlockHasKfsFromYamlNode
        map_package="r2_bt_executor"
        map_file="meilin_map.yaml"
        block="{to_block}"
        has_kfs="{has_kfs}" />

      <Fallback name="skip_or_handle_kfs">

        <Sequence name="skip_when_no_kfs">
          <R2BlackboardCheckBoolNode
            value="{has_kfs}"
            expected="false" />

          <R2ForceSuccess />
        </Sequence>

        <Sequence name="handle_when_has_kfs">

          <R2BlackboardCheckBoolNode
            value="{has_kfs}"
            expected="true" />

          <R2GetBlockKfsHeightFromYamlNode
            map_package="r2_bt_executor"
            map_file="meilin_map.yaml"
            block="{to_block}"
            kfs_height="{kfs_h}" />

          <R2CalculateHeightDeltaNode
            current_h="{current_h}"
            next_h="{kfs_h}"
            delta_h="{kfs_delta_h}" />

          <R2BuildKfsPickActionIdFromYamlNode
            map_package="r2_bt_executor"
            map_file="meilin_map.yaml"
            delta_h="{kfs_delta_h}"
            action_id="{kfs_pick_action_id}" />

          <R2GetArmActionConfigFromYamlNode
            map_package="r2_bt_executor"
            map_file="meilin_map.yaml"
            kfs_suction_arm_target_id="{kfs_suction_arm_target_id}"
            arm_suction_pump_io_id="{arm_suction_pump_io_id}"
            rear_storage_pump_io_id="{rear_storage_pump_io_id}"
            kfs_lift_up_action_id="{kfs_lift_up_action_id}"
            kfs_transfer_to_storage_action_id="{kfs_transfer_to_storage_action_id}" />

          <R2SetEndEffectorNode
            action_name="/r2_arm/set_end_effector"
            io_id="{arm_suction_pump_io_id}"
            state="1"
            hold_ms="0"
            server_timeout_ms="3000"
            result_timeout_ms="10000" />

          <R2ExecuteArmActionNode
            action_name="/r2_arm/execute_action"
            target_id="{kfs_suction_arm_target_id}"
            action_id="{kfs_pick_action_id}"
            timeout_ms="8000"
            param="0"
            flags="0"
            server_timeout_ms="3000"
            result_timeout_ms="10000" />

          <R2ExecuteArmActionNode
            action_name="/r2_arm/execute_action"
            target_id="{kfs_suction_arm_target_id}"
            action_id="{kfs_lift_up_action_id}"
            timeout_ms="8000"
            param="0"
            flags="0"
            server_timeout_ms="3000"
            result_timeout_ms="10000" />

          <R2SetEndEffectorNode
            action_name="/r2_arm/set_end_effector"
            io_id="{rear_storage_pump_io_id}"
            state="1"
            hold_ms="0"
            server_timeout_ms="3000"
            result_timeout_ms="10000" />

          <R2ExecuteArmActionNode
            action_name="/r2_arm/execute_action"
            target_id="{kfs_suction_arm_target_id}"
            action_id="{kfs_transfer_to_storage_action_id}"
            timeout_ms="8000"
            param="0"
            flags="0"
            server_timeout_ms="3000"
            result_timeout_ms="10000" />

          <R2SetEndEffectorNode
            action_name="/r2_arm/set_end_effector"
            io_id="{arm_suction_pump_io_id}"
            state="0"
            hold_ms="0"
            server_timeout_ms="3000"
            result_timeout_ms="10000" />

        </Sequence>

      </Fallback>

      <R2CalculateHeightDeltaNode
        current_h="{current_h}"
        next_h="{next_h}"
        delta_h="{delta_h}" />

      <R2BuildChassisCmdTypeFromYamlNode
        map_package="r2_bt_executor"
        map_file="meilin_map.yaml"
        delta_h="{delta_h}"
        cmd_type="{chassis_cmd_type}" />

      <R2ChassisStepCommandNode
        action_name="/r2_chassis/step_command"
        cmd_type="{chassis_cmd_type}"
        from_block="{current_block}"
        target_block="{to_block}"
        current_h="{current_h}"
        target_h="{next_h}"
        edge_id="{edge_id}"
        timeout_sec="10.0"
        server_timeout_ms="3000"
        result_timeout_ms="15000" />

      <R2SetBlackboardStringNode
        value="{to_block}"
        output="{current_block}" />

      <R2SetBlackboardIntNode
        value="{next_h}"
        output="{current_h}" />

      <R2IncrementIntNode
        input="{route_index}"
        step="1"
        output="{route_index}" />

    </Sequence>
  </BehaviorTree>

</root>