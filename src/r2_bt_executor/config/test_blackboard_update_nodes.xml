<root BTCPP_format="4" main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <Sequence name="test_blackboard_update_nodes">

      <R2SetBlackboardStringNode
        value="B2"
        output="{current_block}" />

      <R2BlackboardCheckStringNode
        value="{current_block}"
        expected="B2" />

      <R2SetBlackboardIntNode
        value="200"
        output="{current_h}" />

      <R2IncrementIntNode
        input="0"
        step="1"
        output="{route_index}" />

      <R2ForceSuccess />

    </Sequence>
  </BehaviorTree>
</root>