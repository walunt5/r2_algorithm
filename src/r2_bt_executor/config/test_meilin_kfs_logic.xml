<root BTCPP_format="4" main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <Sequence name="test_meilin_kfs_logic">

      <R2CheckBlockHasKfsNode
        block="B3"
        has_kfs="{next_block_has_kfs}" />

      <R2BlackboardCheckBoolNode
        value="{next_block_has_kfs}"
        expected="true" />

      <R2GetBlockKfsHeightNode
        block="B3"
        kfs_height="{kfs_target_h}" />

      <R2CalculateHeightDeltaNode
        current_h="0"
        next_h="{kfs_target_h}"
        delta_h="{kfs_delta_h}" />

      <R2BuildKfsPickActionIdByDeltaNode
        delta_h="{kfs_delta_h}"
        action_id="{kfs_pick_action_id}" />

      <R2ForceSuccess />

    </Sequence>
  </BehaviorTree>
</root>